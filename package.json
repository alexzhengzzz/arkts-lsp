{
  "name": "arkts-analyzer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "start:mcp": "node dist/mcp-server.js",
    "workspace:index": "npm run build && node dist/build-workspace-index.js",
    "test": "npm run build && node --test test/**/*.test.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "typescript": "^5.6.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.16.11"
  },
  "engines": {
    "node": ">=20"
  }
}
